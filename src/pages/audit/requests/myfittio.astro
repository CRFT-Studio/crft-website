---
// target audience - Women - Age 25-55 Subpage for pregnant women - https://myfittio.com/prenatal-coaching/

import AuditReport from "@/layouts/AuditReport.astro";

export const auditData = {
  firstName: "Antonio",
  lastName: "Stipic",
  companyName: "myFittio",
  url: "myfittio.com/prenatal-coaching",
  email: "Agencies",
  role: "email",
  date: "March 6th 2026",
  beforeImgPath: "/src/images/audits/myfittio-before.png",
  afterImgPath: "/src/images/audits/myfittio-after.png",
  annotations: [
    {
    question: "Note 1 - NEPPE certification",
    answer: "Make this a tooltip on hover (with an 'i' indicator), explaining what the certification is."
    },
    {
      question: "Note 2 - Desktop and mobile navigation",
      answer: "Enhance mobile navigation by adding a prominent sign-up CTA, ensuring pregnant women can easily access prenatal coaching resources at any point on the page. Move the language selector inside the hamburger menu. <br> <br> On desktop, split the nav links from the CTAs, creating more visual seperation between the two."
    },
    {
      question: "Note 3 - H1 and subtitle",
      answer: "The goal of the H1 is to describe the outcome of MyFittio. The subtitle's job is to explain how you create the value in the H1 — not to restate the outcomes. <br> <br> 'Safe training through pregnancy' attempts the hook strategy by leading with 'safe' — but it's a weak hook because every prenatal fitness brand makes this claim. Safety is table stakes, not a differentiator. It also undersells the product: the real offer isn't just safety, it's a coach who adapts your plan as your pregnancy progresses. That's specific and ownable."
    },
    {
      question: "Note 4 - CTA buttons",
      answer: "Remove the text underneath the primary CTA, and instead incorporate it within the button itself."
    },
    {
      question: "Note 5 - Features list",
      answer: "Move the features at the bottom of the hero to just below the CTA buttons (in the form of a bulleted list), bringing them more in the line of sight."
    },
    {
      question: "Note 6 - Hero image and layout",
      answer: "Opt for a split layout rather than a background image with a pink overlay. This ensures both the copy and pregnant woman are maximally legible, without obstructing one another. <br> <br> Overlay a phone displaying the MyFittio web app, just as on the home page, making it clear to visitors that this is the delivery mechanism for their workout plans."
    }
  ]
};
---
<AuditReport
firstName={auditData.firstName}
lastName={auditData.lastName}
companyName={auditData.companyName}
url={auditData.url}
email={auditData.email}
role={auditData.role}
date={auditData.date}
beforeImgPath={auditData.beforeImgPath}
afterImgPath={auditData.afterImgPath}
annotations={auditData.annotations}
/>
