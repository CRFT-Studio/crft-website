---
import Navigation from "../components/Navigation.astro";
import Testimonials from "../components/Testimonials.astro";
import Footer from "../components/Footer.astro";
import Stripe from "stripe";
import HeadScripts from "../components/HeadScripts.astro";
import HowWeWork from "../components/HowWeWork.astro";
---
<!DOCTYPE html>
<html lang="en">
    <head>
        <style>
        @reference "../styles/global.css";
            #tabs div {
                @apply border-transparent;
            }
            .tab-active {
                border-color: #525252 !important;
                @apply bg-neutral-700;
            }
        </style>
        <HeadScripts
        title="Pricing | CRFT Studio"
        description="A simple, straightforward monthly fee for the length of our project. No contracts or fixed scropes of work. Pause or cancel your subscription as needed."
        ogImageUrl="https://www.crft.studio/open-graph-img.png"
        />
    </head>
    <body>
        <Navigation/>
        <section class="mt-20">
            <div class="container">
                <div class="square-card p-0 bg-transparent flex flex-col gap-16">
                    <div>
                        <div class="square-card bg-transparent border-0 border-b px-0 py-1 text-center text-lg font-normal text-orange-300 mb-12 text-pretty">Web Design & Development Plans</div>
                        <div class="px-8">
                            <div class="flex lg:flex-row flex-col justify-center mb-8 gap-4">
                                <div id="tabs" class="inline-flex flex-row card rounded-none p-[2px] border-[1px] gap-2 text-sm text-nowrap overflow-x-auto">
                                    <div id="monthly" class="tab-active border-[1px] px-2 py-1 hover:cursor-pointer transition-all">Monthly</div>
                                    <div id="quarterly" class="px-2 py-1 border-[1px] hover:cursor-pointer transition-all">Quarterly (Save 10%)</div>
                                    <div id="annually" class="px-2 py-1 border-[1px] hover:cursor-pointer transition-all">Annually (Save 15%)</div>
                                </div>
                                <select id="currency" class="order-first lg:order-last card rounded-none p-[2px] py-2 border-[1px] text-sm text-nowrap overflow-x-auto">
                                    <option value="usd">🇺🇸 USD</option>
                                    <option value="cad">🇨🇦 CAD</option>
                                </select>
                            </div>
                            <h1 class="lg:text-7xl md:text-6xl sm:text-5xl text-[2.6rem] text-center text-balance font-semibold leading-tight lg:mb-7 mb-5"><span id="price">$5000</span><span class="bg-neutral-400 bg-clip-text">/month</span></h1>
                            <div class="text-center lg:text-xl text-lg font-medium leading-normal text-neutral-200 text-pretty max-w-[800px] mx-auto">A simple, straightforward monthly subscription for the length of our project. No contracts or fixed scopes of work. Pause or cancel your subscription as needed. We think of ourselves as an extension of your team, dedicated to designing and developing your website while you work on your core business.</div>
                            <div class="flex flex-row justify-center gap-3 mt-8">
                                <a href="/checkout?plan=monthly" class="primary-cta">Subscribe</a>
                                <a href='/contact-us' class="secondary-cta">Contact Us</a>
                            </div>
                        </div>
                    </div>

                    <div class="bg-neutral-800 p-8 border-t border-neutral-700">
                        <div class="grid lg:grid-cols-3 md:grid-cols-2 grid-cols-1 gap-12 text-pretty">
                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Design work in Figma/Sketch</div>
                                    <div class="text-lg font-normal">We kick off projects by designing initial web/brand concepts, and are receptive to feedback all throughout. Once we're 80% there, we bring ideas to life in code, and make final refinements.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Custom web development</div>
                                    <div class="text-lg font-normal">Astro is our framework of choice. Expect lightning performance, solid technical SEO, and a separate environment to preview updates before they go live.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Headless CMS integration</div>
                                    <div class="text-lg font-normal">We'll integrate Payload CMS into our project, so your team can update and collaborate on content in realtime, without our input.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Daily progress & live updates</div>
                                    <div class="text-lg font-normal">We take in a small number of clients at a time to ensure a close, consistent partnership.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Project management (in Basecamp)</div>
                                    <div class="text-lg font-normal">It keeps everything neat and in one place, from messages, to files, to-do items, and more. You'll love it.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Weekly video call (on request)</div>
                                    <div class="text-lg font-normal">There are occasions where synchonous communcation really helps. For those times, do not hesitate to request a call.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">Pause or cancel anytime</div>
                                    <div class="text-lg font-normal">When our work together is done, you're welcome to pause or cancel your subscription until you need us next.</div>
                                </div>
                            </div>

                            <div class="flex flex-row gap-2 items-start">
                                <svg class="flex-shrink-0" xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#4ade80"><path d="m424-296 282-282-56-56-226 226-114-114-56 56 170 170Zm56 216q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Z"/></svg>
                                <div class="flex flex-col gap-2">
                                    <div class="text-lg font-medium">7-day money-back guarantee</div>
                                    <div class="text-lg font-normal">There are no strings attached. If you don't like our work within the first 7 days of your subscription, we'll refund 100% of your money.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="square-card p-0 bg-transparent mt-8">
                    <div class="square-card py-0 px-1 border-0 border-b text-center text-lg font-normal text-orange-300 text-pretty">Post-Launch Support</div>
                    <div class="p-8">
                        <div class="flex lg:flex-row flex-col justify-center mb-8 gap-4">
                            <select id="support-plan" class="card rounded-none p-[2px] py-2 border-[1px] text-sm text-nowrap overflow-x-auto">
                                <option value="hourly">Hourly</option>
                                <option value="bundle5">5 Hours (Save 5%)</option>
                                <option value="bundle10">10 Hours (Save 10%)</option>
                                <option value="bundle20">20 Hours (Save 15%)</option>
                                <option value="bundle30">30 Hours (Save 20%)</option>
                                <option value="bundle40">40 Hours (Save 25%)</option>
                            </select>
                            <select id="support-currency" class="order-first lg:order-last card rounded-none p-[2px] py-2 border-[1px] text-sm text-nowrap overflow-x-auto">
                                <option value="usd">🇺🇸 USD</option>
                                <option value="cad" selected>🇨🇦 CAD</option>
                            </select>
                        </div>
                        <h1 class="lg:text-7xl md:text-6xl sm:text-5xl text-[2.6rem] font-medium mb-3 leading-tight text-center"><span id="support-price">$100</span><span class="bg-neutral-400 bg-clip-text">/hour</span></h1>
                        <div class="text-lg font-medium leading-normal text-neutral-200 text-pretty text-center max-w-[800px] mx-auto">Flexible hourly support is available for ongoing development needs, and you can opt for bundled hours to save on larger updates or new features. We remain available post-launch to help with optimizations, updates, or feature additions, so you have access to support whenever you need it.</div>
                        <script>
                            import $ from "jquery";

                            //pricing
                            const supportPrices = {
                                hourly: { usd: 75, cad: 100 },
                                bundle5: { usd: 70, cad: 95 },
                                bundle10: { usd: 65, cad: 90 },
                                bundle20: { usd: 60, cad: 85 },
                                bundle30: { usd: 55, cad: 80 },
                                bundle40: { usd: 50, cad: 75 }
                            };

                            function updateSupportPrice() {
                                const activePlan = $("#support-plan").val();
                                const selectedCurrency = $("#support-currency").val();
                                const price = supportPrices[activePlan][selectedCurrency];
                                $("#support-price").text(`$${price.toLocaleString()}`);
                            }

                            updateSupportPrice();

                            $("#support-plan, #support-currency").change(function() {
                                updateSupportPrice();
                            });

                            //posthog n cms choice
                            $("#ph-trigger").click(function() {
                                $("#ph-modal").toggleClass("hidden flex");
                            });
                            $("#ph-modal").click(function(event) {
                                if (!$(event.target).closest('.square-card').length) {
                                    $("#ph-modal").toggleClass("hidden flex");
                                }
                            });

                            $("#cms-trigger").click(function() {
                                $("#cms-modal").toggleClass("hidden flex");
                            });
                            $("#cms-modal").click(function(event) {
                                if (!$(event.target).closest('.square-card').length) {
                                    $("#cms-modal").toggleClass("hidden flex");
                                }
                            });
                        </script>
                    </div>
                </div>
            </div>
        </section>

        <div class="w-full h-[1px] bg-neutral-700 mx-auto"></div>

        <section id="how-we-work-calendar">
            <HowWeWork/>
        </section>

        <div class="w-full h-[1px] bg-neutral-700 mx-auto"></div>

        <Testimonials/>

        <Footer/>

        <script>
            import $ from "jquery";

            const prices = {
                monthly: { usd: 5000, cad: 6850 },
                quarterly: { usd: 4500, cad: 6166 },
                annually: { usd: 4250, cad: 5242 }
            };

            function updatePrice() {
                const activePlan = $(".tab-active").attr("id");
                const selectedCurrency = $("#currency").val();
                const price = prices[activePlan][selectedCurrency];
                $("#price").text(`$${price.toLocaleString()}`);
            }

            function updateCheckoutLink() {
                const activePlan = $(".tab-active").attr("id");
                $(".primary-cta").attr("href", `/checkout?plan=${activePlan}`);
            }

            // Initialize price and checkout link on page load
            updatePrice();
            updateCheckoutLink();

            // Update price and checkout link when tab changes
            $("#tabs div").click(function() {
                if ($(this).hasClass("tab-active")) return;
                $(".tab-active").add(this).toggleClass("tab-active");
                $("#plan").val($(this).attr("id"));
                updatePrice();
                updateCheckoutLink();
            });

            // Update price when currency changes
            $("#currency").change(function() {
                updatePrice();
            });
        </script>

    </body>
</html>
